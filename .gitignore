# API 키나 민감한 정보가 있을 수 있는 파일
.env
*.env

# --- 플러그인별 기기 종속 설정 ---
# Git 플러그인 설정 (PC별로 백업 주기를 다르게 할 경우)
#.obsidian/plugins/obsidian-git/data.json

# 테마/UI 관련 캐시
.obsidian/appearance.json

# --- Obsidian 작업 상태 (기기별로 달라야 하는 것) ---
# 현재 열려있는 탭, 사이드바 상태 등 (가장 빈번한 충돌 원인)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
# 그래프 뷰의 애니메이션/위치 상태
.obsidian/graph.json
# 플러그인 캐시 및 인덱스 데이터
.obsidian/cache/
.trash/

# --- OS 생성 파일 (Mac/Windows 혼용 시 필수) ---
.AppleDouble
.LSOverride
Icon?
# Windows 시스템 파일
Thumbs.db
desktop.ini
# Mac 시스템 파일
.DS_Store